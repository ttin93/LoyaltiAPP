# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Polar (Merchant of Record) — naročnine lokalov. Glej docs/POLAR.md
# Za TESTIRANJE odkomentiraj sandbox (loči se od produkcije, brez pravih bremenitev):
# POLAR_API_BASE=https://sandbox-api.polar.sh
POLAR_API_TOKEN=polar_oat_xxx
POLAR_WEBHOOK_SECRET=polar_whs_xxx
# Naročninski produkti (Polar dashboard → Products → recurring). Prilepi product ID-je:
POLAR_PRODUCT_ESPRESSO_MONTHLY_ID=
POLAR_PRODUCT_ESPRESSO_YEARLY_ID=
POLAR_PRODUCT_DOPPIO_MONTHLY_ID=
POLAR_PRODUCT_DOPPIO_YEARLY_ID=
# Javni URL aplikacije (za success_url checkouta). Na Vercelu pravi domen.
NEXT_PUBLIC_SITE_URL=https://loyalti-app-blond.vercel.app

# E-pošta (Resend) — kampanje lokal→gost + super-admin→lastniki.
# Rabi VERIFICIRANO domeno + SPF/DKIM/DMARC v Resend, sicer gre v spam.
RESEND_API_KEY=re_xxx
RESEND_FROM="Loyavi <pozdrav@loyavi.app>"
# Kam pristanejo odgovori (from-domena nima inboxa). Daj svoj Gmail za začetek:
RESEND_REPLY_TO=tin.suklje93@gmail.com

# Cron (Vercel) — dnevni avtomatizacijski maili (/api/cron/daily). Poljuben dolg niz.
CRON_SECRET=
